APP_NAME="Notification Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8080

LOG_CHANNEL=stderr
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=notifications
DB_USERNAME=notifications
DB_PASSWORD=secret


CACHE_STORE=redis
SESSION_DRIVER=array
QUEUE_CONNECTION=sync

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0
REDIS_CACHE_DB=1


RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/


NOTIFICATIONS_EXCHANGE=notifications
NOTIFICATIONS_QUEUE_HIGH=notifications.high
NOTIFICATIONS_QUEUE_LOW=notifications.low

NOTIFICATIONS_QUEUE_MAX_PRIORITY=10
NOTIFICATIONS_PREFETCH=10

IDEMPOTENCY_TTL_SECONDS=86400

SMS_PROVIDER_FAIL_RATE=0.05
EMAIL_PROVIDER_FAIL_RATE=0.05


APP_HTTP_PORT=8080
DB_FORWARD_PORT=5432
REDIS_FORWARD_PORT=6379
RABBITMQ_AMQP_PORT=5672
RABBITMQ_UI_PORT=15672
SWAGGER_PORT=8081